{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Go: Test",
      "type": "shell",
      "command": "GOCACHE=/tmp/go-build go test ./...",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$go",
      "group": "test"
    },
    {
      "label": "Go: Run Server",
      "type": "shell",
      "command": "go run ./cmd/server -config server.yml",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$go"
    },
    {
      "label": "Go: Tidy",
      "type": "shell",
      "command": "go mod tidy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$go"
    }
  ]
}
